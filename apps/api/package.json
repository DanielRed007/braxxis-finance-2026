    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
