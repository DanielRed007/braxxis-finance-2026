generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  hashedPassword String       @map("hashed_password")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  profile        Profile?
  paperWallet    PaperWallet?

  @@map("users")
}

model Profile {
  userId               String   @id @map("user_id")
  firstName            String   @map("first_name")
  lastName             String   @map("last_name")
  phone                String   @default("")
  dateOfBirth          String   @default("") @map("date_of_birth")
  country              String   @default("")
  city                 String   @default("")
  address              String   @default("")
  postalCode           String   @default("") @map("postal_code")
  taxId                String   @default("") @map("tax_id")
  employmentStatus     String   @default("") @map("employment_status")
  employer             String   @default("")
  jobTitle             String   @default("") @map("job_title")
  investmentExperience String   @default("") @map("investment_experience")
  riskTolerance        String   @default("") @map("risk_tolerance")
  annualIncome         String   @default("") @map("annual_income")
  netWorth             String   @default("") @map("net_worth")
  investmentGoal       String   @default("") @map("investment_goal")
  sourceOfFunds        String   @default("") @map("source_of_funds")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("profiles")
}

model PaperWallet {
  id        String      @id @default(uuid())
  userId    String      @unique @map("user_id")
  balance   Decimal     @default(100000) @db.Decimal(18, 8)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id])
  holdings Holding[]
  orders   SpotOrder[]

  @@map("paper_wallets")
}

model Holding {
  id        String      @id @default(uuid())
  walletId  String      @map("wallet_id")
  symbol    String
  quantity  Decimal     @default(0) @db.Decimal(18, 8)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  wallet PaperWallet @relation(fields: [walletId], references: [id])

  @@unique([walletId, symbol])
  @@map("holdings")
}

model SpotOrder {
  id         String      @id @default(uuid())
  walletId   String      @map("wallet_id")
  symbol     String
  side       String
  quantity   Decimal     @db.Decimal(18, 8)
  price      Decimal     @db.Decimal(18, 8)
  total      Decimal     @db.Decimal(18, 8)
  executedAt DateTime    @default(now()) @map("executed_at")

  wallet PaperWallet @relation(fields: [walletId], references: [id])

  @@map("spot_orders")
}
