    "@braxxis/shared": "workspace:*",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.0.0",
    "reflect-metadata": "^0.2.0",
    "tsyringe": "^4.8.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "prisma": "^6.2.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
